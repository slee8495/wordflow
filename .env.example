# --- Database (Neon Postgres via Vercel Marketplace) ---
DATABASE_URL=

# --- AI Gateway (chat model, TTS, transcription) ---
AI_GATEWAY_API_KEY=

# --- Bible text sources ---
# Tyndale NLT API — https://api.nlt.to (free for non-commercial use)
NLT_API_KEY=
# API.Bible (American Bible Society) — https://api.bible, for Korean 새번역 (or 개역개정 fallback)
BIBLE_API_KEY=
BIBLE_API_KO_BIBLE_ID=

# --- YouTube Data API v3 (worship/sermon auto-search) ---
YOUTUBE_API_KEY=

# --- Cron / API auth ---
# Random secret; Vercel Cron sends it as `Authorization: Bearer <value>` automatically once set
# as a project env var — see https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=
# Shared secret for any non-browser caller of /api/transcribe (mirrors sl_sports' KEYBOARD_API_KEY)
APP_API_KEY=
